<main>
<section class="section"><div class="container"><div class="contact-grid">
  <div>
    <p class="eyebrow">Contact</p><h1>Get in touch</h1>
    <p class="copy">If you are looking for a psychotherapist in London Bridge or online therapy across London, including Soho, Shoreditch or Islington, you are welcome to get in touch to ask a question or arrange an initial consultation.</p>
    <div class="contact-row"><span class="icon">✉</span><span>jmosstherapy@gmail.com</span></div>
    <div class="contact-row"><span class="icon">◷</span><span>Weekday daytime and evening online appointments</span></div>
    <div class="contact-row"><span class="icon">£</span><span>Sessions: £105 per 50-minute session</span></div>
    <div style="margin-top:32px;">
      <!-- Professional verification provided by Psychology Today -->
      <a href="https://www.psychologytoday.com/profile/1728375" class="sx-verified-seal"></a>
      <script type="text/javascript" src="https://member.psychologytoday.com/verified-seal.js" data-badge="16" data-id="1728375" data-code="aHR0cHM6Ly93d3cucHN5Y2hvbG9neXRvZGF5LmNvbS9hcGkvdmVyaWZpZWQtc2VhbC9zZWFscy8xNi9wcm9maWxlLzE3MjgzNzU/Y2FsbGJhY2s9c3hjYWxsYmFjaw=="></script>
      <!-- End Verification -->
   <div style="margin-top:24px;">
  <a href="https://www.bacp.co.uk/therapists/420086/jake-moss/london-se1?search=jake%20moss"
     target="_blank"
     rel="noopener noreferrer">
    <img src="bacp-logo.png"
         alt="BACP Registered Member"
         style="width:260px; max-width:100%; height:auto; display:block;">
  </a>
</div>
    </div>
  </div>
  <div class="form-card">
    <form action="https://formspree.io/f/xqegwjjb" method="POST">
      <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" placeholder="Your name" required></div>
      <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" placeholder="Your email address" required></div>
      <div class="field"><label for="message">Message</label><textarea id="message" name="message" placeholder="How can I help?" required></textarea></div>
      <button type="submit" class="button-submit">Send Enquiry</button>
      <p class="form-note">Your enquiry will be sent directly from the website.</p>
    </form>
  </div>
</div></div></section>
